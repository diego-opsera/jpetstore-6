{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(*git commit*)",
            "command": ".claude/hooks/forge-pre-commit.sh",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
